# =============================================================================
# .gitignore — mvgwas-pipeline
# =============================================================================

# Output directories
output/
results/
work/
*.work/

# Chromosome VCFs (large; regenerated by pipeline)
chr_vcfs/
chr_results/

# User config files (contain paths; copy template instead)
*.conf
!config.conf.template

# Logs
logs/
*.log

# Nextflow work dir
.nextflow/
.nextflow.log*

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# R
.Rhistory
.RData
.Rproj.user/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Editors
.vscode/
.idea/
*.swp
*~

# Singularity cache
.singularity/
singularity_images/

# Temporary files
*.tmp
*.bak
*.orig
tmp/
temp/

# Checkpoints (these live inside OUTPUT_DIR)
.checkpoints/
