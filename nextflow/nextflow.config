// =============================================================================
// nextflow/nextflow.config  —  Custom Nextflow config for mvgwas-pipeline
// =============================================================================
// This file is passed via `-c` to each `nextflow run` invocation.
// Adjust executor, CPU, and memory settings to match your HPC/local system.
// =============================================================================

manifest {
    name        = 'mvgwas-nf'
    description = 'Multi-variate GWAS pipeline (KahinaBch/mvgwas-nf kb/dsl2-conversion)'
    version     = '1.0'
    nextflowVersion = '!>=21.04.0'
}

// ----------------------------------------------------------------------------
// Default process settings (overridden by profiles)
// ----------------------------------------------------------------------------
process {
    errorStrategy = 'retry'
    maxRetries    = 2
    cpus          = 2
    memory        = '8 GB'
    time          = '4 h'
}

// ----------------------------------------------------------------------------
// Profiles
// ----------------------------------------------------------------------------
profiles {

    // ── Local execution (no HPC) ─────────────────────────────────────────────
    local {
        executor {
            name     = 'local'
            cpus     = 8
            memory   = '32 GB'
        }
        process {
            cpus   = 2
            memory = '8 GB'
        }
    }

    // ── SLURM execution ──────────────────────────────────────────────────────
    slurm {
        executor {
            name           = 'slurm'
            queueSize      = 50
            submitRateLimit = '10 sec'
        }
        process {
            executor  = 'slurm'
            queue     = params.slurm_partition ?: 'genoa'
            cpus      = 4
            memory    = '32 GB'
            time      = '24 h'
            clusterOptions = "--parsable"
        }
    }

    // ── Singularity ──────────────────────────────────────────────────────────
    singularity {
        singularity {
            enabled    = true
            autoMounts = true
        }
    }

    // ── Docker ───────────────────────────────────────────────────────────────
    docker {
        docker {
            enabled = true
        }
    }

    // ── Combined: SLURM + Singularity (most common HPC setup) ────────────────
    hpc {
        executor {
            name            = 'slurm'
            queueSize       = 50
            submitRateLimit = '10 sec'
        }
        process {
            executor  = 'slurm'
            queue     = params.slurm_partition ?: 'genoa'
            cpus      = 4
            memory    = '32 GB'
            time      = '24 h'
        }
        singularity {
            enabled    = true
            autoMounts = true
        }
    }
}

// ----------------------------------------------------------------------------
// Nextflow reports and tracing
// ----------------------------------------------------------------------------
report {
    enabled  = true
    file     = "${params.dir ?: 'results'}/nextflow_report.html"
    overwrite = true
}

timeline {
    enabled  = true
    file     = "${params.dir ?: 'results'}/nextflow_timeline.html"
    overwrite = true
}

trace {
    enabled  = true
    file     = "${params.dir ?: 'results'}/nextflow_trace.txt"
    overwrite = true
    fields   = 'task_id,hash,native_id,name,status,exit,submit,start,complete,duration,realtime,cpus,memory,%cpu,%mem,rss'
}

// ----------------------------------------------------------------------------
// Tower / Seqera cloud (optional; uncomment to enable)
// ----------------------------------------------------------------------------
// tower {
//     enabled  = true
//     endpoint = 'https://tower.nf'
// }
